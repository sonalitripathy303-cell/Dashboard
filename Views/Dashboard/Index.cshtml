@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark px-4">
        <span class="navbar-brand mb-0 h1">Dashboard</span>
        <a asp-action="Logout" asp-controller="Account" class="btn btn-danger btn-sm">Logout</a>
    </nav>

    <div class="container mt-5">
        <div class="p-5 bg-white border rounded shadow-sm mb-4">
            <h1 class="display-5 text-success">Welcome back, @ViewBag.Username!</h1>
            <p class="lead">You have successfully logged in using a secure JWT token cookie configuration backed by custom ADO.NET query execution architecture.</p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-secondary text-white fw-bold">
                🛠️ Main Operations & Inventory Menu
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="p-3 border rounded text-center bg-white">
                            <h5>Inventory Center</h5>
                            <p class="small text-muted">Manage items, view current stock quantites, and log product sales.</p>
                            <a asp-action="ItemManagement" asp-controller="Dashboard" class="btn btn-success btn-sm w-100">
                                Open Item Management
                            </a>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 border rounded text-center bg-white">
                            <h5>Reports Engine</h5>
                            <p class="small text-muted">Query custom items, calculate system prices, and print formal audit statements.</p>
                            <a asp-action="Report" asp-controller="Dashboard" class="btn btn-info btn-sm w-100 text-white">
                                Generate Statement Report
                            </a>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 border rounded text-center bg-white">
                            <h5>Account Workspace</h5>
                            <p class="small text-muted">View your secure database user registration configuration parameters.</p>
                            <a asp-action="Profile" asp-controller="Dashboard" class="btn btn-primary btn-sm w-100">
                                View My Profile
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>