@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>

    <nav class="navbar navbar-dark bg-dark px-4">
        <span class="navbar-brand mb-0 h1">Dashboard</span>
        <a asp-action="Logout" asp-controller="Account" class="btn btn-danger btn-sm">Logout</a>
    </nav>

    <div class="container mt-5">
        <div class="p-5 bg-white border rounded shadow-sm">
            <h1 class="display-5 text-success">Welcome back, @ViewBag.Username!</h1>
            <p class="lead">You have successfully logged in using a manual ASP.NET Core session configuration backed by custom ADO.NET query execution architecture.</p>
        </div>
    </div>

    <a asp-action="Profile" asp-controller="Dashboard" class="btn btn-primary mt-3">View My Profile</a>

</body>
</html>