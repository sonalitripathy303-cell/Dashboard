@model LoginToDashboard.Models.ProfileModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>User Profile</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark px-4">
        <span class="navbar-brand mb-0 h1">Secure Control Room</span>
        <div>
            <a asp-action="Index" asp-controller="Dashboard" class="btn btn-outline-light btn-sm me-2">Back to Dashboard</a>
            <a asp-action="Logout" asp-controller="Account" class="btn btn-danger btn-sm">Logout</a>
            }
        </div>
    </nav>

    <div class="container mt-5">
        <div class="card mx-auto shadow-sm" style="max-width: 500px;">
            <div class="card-header bg-primary text-white text-center">
                <h4>My Profile</h4>
            </div>
            <div class="card-body">
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                }

                <div class="mb-3 row">
                    <label class="col-sm-4 col-form-label fw-bold">User ID:</label>
                    <div class="col-sm-8">
                        <input type="text" readonly class="form-control-plaintext" value="@Model.UserId">
                    </div>
                </div>

                <div class="mb-3 row">
                    <label class="col-sm-4 col-form-label fw-bold">Username:</label>
                    <div class="col-sm-8">
                        <input type="text" readonly class="form-control-plaintext" value="@Model.Username">
                    </div>
                </div>

                <div class="mb-3 row">
                    <label class="col-sm-4 col-form-label fw-bold">Account Status:</label>
                    <div class="col-sm-8">
                        <span class="badge bg-success">Active Secure User</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
